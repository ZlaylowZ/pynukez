# Nukez Testing Kit Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# REQUIRED: Solana Configuration
# =============================================================================

# Path to your Solana keypair JSON file
# Generate one with: solana-keygen new --outfile ~/.config/solana/id.json
SOLANA_KEYPAIR=/Users/zhanson/.keys/solana_key.json

# Network: devnet (testing) or mainnet-beta (production)
NUKEZ_NETWORK=devnet

# Nukez API URL
NUKEZ_BASE_URL=https://api.nukez.xyz

# =============================================================================
# OPTIONAL: LLM Configuration (for autonomous agent tests)
# =============================================================================

# Anthropic API key (for Claude models)
# Get one at: https://console.anthropic.com/
ANTHROPIC_API_KEY=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

# OpenAI API key (for GPT models)  
# Get one at: https://platform.openai.com/
OPENAI_API_KEY=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

# Which model to use for agent tests
# Examples: claude-sonnet-4-20250514, gpt-4o, gpt-4o-mini
NUKEZ_LLM_MODEL=claude-sonnet-4-20250514
RPC_URL=https://devnet.helius-rpc.com/?api-key=c415c962-6a30-4924-8943-907e5698779f
# =============================================================================
# TEST CONFIGURATION
# =============================================================================

# Enable live API tests (requires devnet SOL)
# Set to 1 to enable, 0 to disable
NUKEZ_LIVE_TEST=0

# Agent test mode: human_guided or fully_autonomous
NUKEZ_AGENT_MODE=human_guided

# Maximum iterations for agent tests
MAX_ITERATIONS=15

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
